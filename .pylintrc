[MASTER]
load-plugins=pylint.extensions.typecheck

[MESSAGES CONTROL]
disable=missing-docstring,invalid-name,too-few-public-methods

[TYPECHECK]
generated-members=*
ignored-modules=google.*,playwright.*,pandas.*,numpy.*,structlog.*,functions_framework.*,flask.*,email_validator.*,httpx.*,keyring.*

[FORMAT]
max-line-length=120
