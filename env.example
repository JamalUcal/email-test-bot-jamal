# Local Development Environment Variables
# Copy this file to .env and fill in your values

# Google Cloud Service Account
# Path to your service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# GCP Project Configuration (optional - for Secret Manager access)
GCP_PROJECT_ID=your-project-id
GCP_SECRET_NAME=service-account-key

# Scraper Credentials
# Format: SCRAPER_SUPPLIER_NAME_USERNAME and SCRAPER_SUPPLIER_NAME_PASSWORD
# These must match the username_env/password_env values in scraper_config.json

# AUTOCAR credentials
SCRAPER_AUTOCAR_USERNAME=your@email.com
SCRAPER_AUTOCAR_PASSWORD=yourpassword

# NEOPARTA credentials
SCRAPER_NEOPARTA_USERNAME=your@email.com
SCRAPER_NEOPARTA_PASSWORD=yourpassword

# BRECHMANN credentials
SCRAPER_BRECHMANN_USERNAME=your@email.com
SCRAPER_BRECHMANN_PASSWORD=yourpassword

# CONNEX credentials
SCRAPER_CONNEX_USERNAME=your_username
SCRAPER_CONNEX_PASSWORD=yourpassword

# TECHNOPARTS credentials
SCRAPER_TECHNOPARTS_USERNAME=your@email.com
SCRAPER_TECHNOPARTS_PASSWORD=yourpassword

# MATEROM credentials
SCRAPER_MATEROM_USERNAME=your@email.com
SCRAPER_MATEROM_PASSWORD=yourpassword

# APF credentials (legacy example)
SCRAPER_APF_USERNAME=your@email.com
SCRAPER_APF_PASSWORD=yourpassword


